DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_application_id

# Optional: numeric server ID only (Discord: enable Developer Mode → right‑click server → Copy Server ID).
# Leave blank to register slash commands globally (can take up to ~1 hour to show everywhere).
DISCORD_GUILD_ID=

# IANA timezone used for Friday 23:59 cutoff and event dates (e.g. America/New_York)
SERVER_TIMEZONE=America/New_York

# Optional: role ID that may use admin commands (if unset, Discord Administrator permission is required)
DISCORD_ADMIN_ROLE_ID=

# Optional: assign this role to #1 on event leaderboard after /finalize_scores (manual follow-up or extend bot)
TOP_PREDICTOR_ROLE_ID=

# SQLite path (default ./data/bot.sqlite in code if unset)
DATABASE_PATH=./data/bot.sqlite
